---
const {navName, ...rest} = Astro.props;
---

<header>
    <nav>
        <h3><a class={navName == "home" ? "" : "reveal"} href="/">home</a> •&nbsp;</h3>
        <h3><a class={navName == "about" ? "" : "reveal"} href="/about">about me</a> •&nbsp;</h3>
        <h3><a class={navName == "blog" ? "" : "reveal"} href="/blog">blog</a> •&nbsp;</h3>
        <h3><a class={navName == "contact" ? "" : "reveal"} href="/contact">contact</a></h3>
    </nav>
    <hr>
</header>

<style>

    #on {
        color: red;
    }


    header {
        /* min-height: 20em; */
        background-image: linear-gradient(#000, #0000);
    }
    nav {
        /* margin-top: 5em; */
    }
    h3 {
        display: inline-block;
        white-space: nowrap;
    }

    h3 {
        @media screen and (max-width: 800px) {
            display: none;
        }
    }
</style>